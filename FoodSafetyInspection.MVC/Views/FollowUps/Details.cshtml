@model FoodSafetyInspection.Domain.FollowUp

@{
    ViewData["Title"] = "Follow-Up Details";
    var isOverdue = Model.Status == "Open" && Model.DueDate < DateTime.Today;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Follow-Up Details</h1>
        <p class="text-muted mb-0">@Model.Inspection?.Premises?.Name — Due @Model.DueDate.ToShortDateString()</p>
    </div>
    @if (isOverdue)
    {
        <span class="badge bg-danger fs-6">⚠️ Overdue</span>
    }
    else if (Model.Status == "Closed")
    {
        <span class="badge bg-success fs-6">✅ Closed</span>
    }
    else
    {
        <span class="badge bg-warning text-dark fs-6">🕐 Open</span>
    }
</div>

<!-- Follow-Up Info Card -->
<div class="card shadow-sm mb-4">
    <div class="card-header table-dark text-black">
        <h5 class="mb-0">Follow-Up Information</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Premises</dt>
            <dd class="col-sm-9">
                <a asp-controller="Premises" asp-action="Details"
                   asp-route-id="@Model.Inspection?.PremisesId">
                    @Model.Inspection?.Premises?.Name
                </a>
            </dd>

            <dt class="col-sm-3">Inspection Date</dt>
            <dd class="col-sm-9">
                <a asp-controller="Inspections" asp-action="Details"
                   asp-route-id="@Model.InspectionId">
                    @Model.Inspection?.InspectionDate.ToShortDateString()
                </a>
            </dd>

            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">
                @Model.DueDate.ToShortDateString()
                @if (isOverdue)
                {
                    var daysOverdue = (DateTime.Today - Model.DueDate).Days;
                    <span class="badge bg-danger ms-2">@daysOverdue day(s) overdue</span>
                }
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.Status == "Open" ? "bg-warning text-dark" : "bg-success")">
                    @Model.Status
                </span>
            </dd>

            <dt class="col-sm-3">Closed Date</dt>
            <dd class="col-sm-9">
                @(Model.ClosedDate.HasValue? Model.ClosedDate.Value.ToShortDateString() : "N/A")
            </dd>
        </dl>
    </div>
</div>

<!-- Action Buttons -->
<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to List
    </a>
    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning ms-2">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
    }
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger ms-2">
            <i class="bi bi-trash me-1"></i> Delete
        </a>
    }
</div>