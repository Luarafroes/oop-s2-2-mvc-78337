@model FoodSafetyInspection.Domain.Inspection

@{
    ViewData["Title"] = "Inspection Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Inspection Details</h1>
        <p class="text-muted mb-0">@Model.Premises?.Name — @Model.InspectionDate.ToShortDateString()</p>
    </div>
    <span class="badge fs-6 @(Model.Outcome == "Pass" ? "bg-success" : "bg-danger")">
        @(Model.Outcome == "Pass" ? "✅" : "❌") @Model.Outcome
    </span>
</div>

<!-- Inspection Info Card -->
<div class="card shadow-sm mb-4">
    <div class="card-header table-dark text-black">
        <h5 class="mb-0">Inspection Information</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Premises</dt>
            <dd class="col-sm-9">
                <a asp-controller="Premises" asp-action="Details" asp-route-id="@Model.PremisesId">
                    @Model.Premises?.Name
                </a>
            </dd>

            <dt class="col-sm-3">Inspection Date</dt>
            <dd class="col-sm-9">@Model.InspectionDate.ToShortDateString()</dd>

            <dt class="col-sm-3">Score</dt>
            <dd class="col-sm-9">
                <div class="d-flex align-items-center gap-2">
                    <div class="progress" style="height: 20px; width: 150px;">
                        <div class="progress-bar @(Model.Score >= 60 ? "bg-success" : "bg-danger")"
                             style="width: @Model.Score%">
                            @Model.Score
                        </div>
                    </div>
                    <small class="text-muted">out of 100</small>
                </div>
            </dd>

            <dt class="col-sm-3">Outcome</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.Outcome == "Pass" ? "bg-success" : "bg-danger")">
                    @Model.Outcome
                </span>
            </dd>

            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@Model.Notes</dd>
        </dl>
    </div>
</div>

<!-- Follow-Ups Card -->
<h3>Follow-Ups</h3>
<div class="card shadow-sm mb-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Closed Date</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.FollowUps.Any())
                {
                    @foreach (var followUp in Model.FollowUps)
                    {
                        <tr class="@(followUp.Status == "Open" && followUp.DueDate < DateTime.Today ? "table-danger" : "")"
                            onclick="window.location.href='@Url.Action("Details", "FollowUps", new { id = followUp.Id })'"
                            style="cursor: pointer;"
                            title="Click to view follow-up details">
                            <td>@followUp.DueDate.ToShortDateString()</td>
                            <td>
                                <span class="badge @(followUp.Status == "Open" ? "bg-warning text-dark" : "bg-success")">
                                    @followUp.Status
                                </span>
                            </td>
                            <td>@(followUp.ClosedDate.HasValue? followUp.ClosedDate.Value.ToShortDateString() : "N/A")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-3">
                            No follow-ups recorded for this inspection
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Action Buttons -->
<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to List
    </a>
    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning ms-2">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
    }
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger ms-2">
            <i class="bi bi-trash me-1"></i> Delete
        </a>
    }
</div>