@model FoodSafetyInspection.Domain.Premises

@{
    ViewData["Title"] = "Premises Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">@Model.Name</h1>
    @if (ViewBag.OverdueCount > 0)
    {
        <span class="badge bg-danger fs-6">
            ⚠️ @ViewBag.OverdueCount Overdue Follow-Up(s)
        </span>
    }
    else
    {
        <span class="badge bg-success fs-6">
            ✅ No Overdue Follow-Ups
        </span>
    }
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@Model.Address</dd>

            <dt class="col-sm-3">Town</dt>
            <dd class="col-sm-9">@Model.Town</dd>

            <dt class="col-sm-3">Risk Rating</dt>
            <dd class="col-sm-9">
                <span class="badge rounded-pill @(Model.RiskRating == "High" ? "bg-danger" : Model.RiskRating == "Medium" ? "bg-warning text-dark" : "bg-success")">
                    @Model.RiskRating
                </span>
            </dd>
        </dl>
    </div>
</div>

<h3>Inspections</h3>
<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Score</th>
                    <th>Outcome</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Inspections.Any())
                {
                    @foreach (var inspection in Model.Inspections.OrderByDescending(i => i.InspectionDate))
                    {
                        <tr onclick="window.location.href='@Url.Action("Details", "Inspections", new { id = inspection.Id })'"
                            style="cursor: pointer;"
                            title="Click to view inspection details">
                            <td>@inspection.InspectionDate.ToShortDateString()</td>
                            <td>
                                <div class="progress" style="height: 20px; width: 100px;">
                                    <div class="progress-bar @(inspection.Score >= 60 ? "bg-success" : "bg-danger")"
                                         style="width: @inspection.Score%">
                                        @inspection.Score
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge @(inspection.Outcome == "Pass" ? "bg-success" : "bg-danger")">
                                    @inspection.Outcome
                                </span>
                            </td>
                            <td>@inspection.Notes</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-3">
                            No inspections recorded yet
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to List
    </a>
    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning ms-2">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
    }
</div>