@model IEnumerable<FoodSafetyInspection.Domain.Premises>

@{
    ViewData["Title"] = "Premises";
}

<h1>Premises</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">Add New Premises</a>
}

<!-- Search Form - Mixed Approach -->
<form method="get" asp-action="Index" class="row g-3 mb-4" id="filterForm">
    <div class="col-md-4">
        <input type="text" name="searchName" id="liveSearchName"
               value="@ViewBag.SearchName"
               class="form-control" placeholder="Search by name..."
               autocomplete="off" />
        
    </div>
    <div class="col-md-3">
        <select name="searchTown" id="townFilter" class="form-control">
            <option value="">-- All Towns --</option>
            @foreach (var town in ViewBag.Towns as List<string> ?? new List<string>())
            {
                <option value="@town" selected="@(ViewBag.SearchTown == town)">@town</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="searchRiskRating" id="riskFilter" class="form-control">
            <option value="">-- All Risk Ratings --</option>
            <option value="Low" selected="@(ViewBag.SearchRiskRating == "Low")">Low</option>
            <option value="Medium" selected="@(ViewBag.SearchRiskRating == "Medium")">Medium</option>
            <option value="High" selected="@(ViewBag.SearchRiskRating == "High")">High</option>
        </select>
    </div>
    <div class="col-md-2 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Apply Filters</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<!-- Results Count -->
<div id="resultsCount" class="mb-2"></div>

<table class="table table-striped" id="premisesTable">
    <thead>
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Town</th>
            <th>Risk Rating</th>
            <th>Actions</th>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr data-name="@item.Name.ToLower()"
                data-town="@item.Town"
                data-risk="@item.RiskRating">
                <td>@item.Name</td>
                <td>@item.Address</td>
                <td>@item.Town</td>
                <td>
                    <span class="badge @(item.RiskRating == "High" ? "bg-danger" : item.RiskRating == "Medium" ? "bg-warning text-dark" : "bg-success")">
                        @item.RiskRating
                    </span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        // Get all table rows
        const rows = document.querySelectorAll('#premisesTable tbody tr');
        const resultsCountDiv = document.getElementById('resultsCount');

        // Live search function
        function filterTable() {
            const searchTerm = document.getElementById('liveSearchName').value.toLowerCase();
            const townFilter = document.getElementById('townFilter').value;
            const riskFilter = document.getElementById('riskFilter').value;

            let visibleCount = 0;

            rows.forEach(row => {
                const name = row.getAttribute('data-name');
                const town = row.getAttribute('data-town');
                const risk = row.getAttribute('data-risk');

                // Check all filters
                const matchesName = searchTerm === '' || name.includes(searchTerm);
                const matchesTown = townFilter === '' || town === townFilter;
                const matchesRisk = riskFilter === '' || risk === riskFilter;

                if (matchesName && matchesTown && matchesRisk) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Update results count
            const totalCount = rows.length;
            resultsCountDiv.innerHTML = `<small class="text-muted">Showing ${visibleCount} of ${totalCount} premises</small>`;

            // Show message if no results
            if (visibleCount === 0) {
                resultsCountDiv.innerHTML += `<div class="alert alert-info mt-2">No premises match your filters</div>`;
            }
        }

        // Attach live search to text input (on each keystroke)
        const liveSearchInput = document.getElementById('liveSearchName');
        if (liveSearchInput) {
            liveSearchInput.addEventListener('input', filterTable);
        }

        // Attach to dropdowns too for instant filtering
        const townSelect = document.getElementById('townFilter');
        const riskSelect = document.getElementById('riskFilter');

        if (townSelect) townSelect.addEventListener('change', filterTable);
        if (riskSelect) riskSelect.addEventListener('change', filterTable);

        // Initial count
        filterTable();
    </script>
}